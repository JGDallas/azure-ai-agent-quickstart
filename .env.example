# ============================================================
# Azure AI Agent Quickstart — environment configuration
#
# Copy this file to `.env` (run.sh will do it for you on first
# invocation) and fill in the REQUIRED values. Lines marked
# "# REQUIRED" must be set before the app will start.
# ============================================================

# ==================== REQUIRED ====================
# Azure OpenAI resource endpoint. Find it in the Azure Portal:
#   Azure OpenAI resource > Keys and Endpoint > "Endpoint".
# Example: https://my-aoai.openai.azure.com
# REQUIRED
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API key (KEY 1 or KEY 2 on the same portal blade).
# REQUIRED
AZURE_OPENAI_API_KEY=

# The DEPLOYMENT name you chose when you deployed gpt-4o-mini
# in Azure AI Foundry / Azure OpenAI Studio. This is NOT the
# model name — you pick it yourself at deploy time. The default
# below only works if you literally named your deployment
# "gpt-4o-mini".
# REQUIRED
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version. Leave as-is unless you know you need another.
# REQUIRED
AZURE_OPENAI_API_VERSION=2024-10-21


# ==================== BUDGETS ====================
# Per-session caps. The UI shows a progress bar for each and the
# backend refuses to continue a turn that would blow the budget.

# Hard cap on total tokens per session.
SESSION_TOKEN_BUDGET=200000

# Hard cap on estimated spend per session, in USD.
SESSION_USD_BUDGET=2.00

# Price table per 1,000,000 tokens. Defaults match the public
# gpt-4o-mini list price at time of writing. Override if you
# negotiated different pricing or want to simulate another model.
PRICE_TABLE_JSON={"gpt-4o-mini":{"input":0.15,"output":0.60}}


# ==================== OPTIONAL: Azure AI Search ====================
# If all three are set, the Research Assistant agent uses Azure
# AI Search. Otherwise it falls back to a local SQLite FTS5 index
# seeded from api/sample_docs/*.md — you still get a working demo.

AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_KEY=
AZURE_AI_SEARCH_INDEX=quickstart-docs


# ==================== OPTIONAL: Application Insights ====================
# If set, traces are also sent to Application Insights via the
# azure-monitor-opentelemetry distro. The UI still reads from the
# in-memory ring buffer either way.

APPLICATIONINSIGHTS_CONNECTION_STRING=
