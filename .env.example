# ============================================================
# Azure AI Agent Quickstart — environment configuration
#
# Copy this file to `.env` (run.sh will do it for you on first
# invocation) and fill in the vars for the provider you pick.
# Only the block matching LLM_PROVIDER is required; the others
# can stay blank.
# ============================================================

# ==================== REQUIRED: pick one provider ====================
# azure | openai | anthropic
# REQUIRED
LLM_PROVIDER=azure


# ==================== Azure OpenAI ====================
# Required when LLM_PROVIDER=azure.

# Endpoint, e.g. https://my-aoai.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# API key (Keys & Endpoint blade in the Azure Portal)
AZURE_OPENAI_API_KEY=

# Deployment name you picked when you deployed gpt-4o-mini
# (NOT the model name — you choose this at deploy time)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version — leave as-is unless you know you need another
AZURE_OPENAI_API_VERSION=2024-10-21


# ==================== OpenAI ====================
# Required when LLM_PROVIDER=openai.

# API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Model id, e.g. gpt-4o-mini, gpt-4o, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini


# ==================== Anthropic ====================
# Required when LLM_PROVIDER=anthropic.
# Note: this branch's Phase 1 wires Azure and OpenAI only;
# Anthropic lands in Phase 2. Leave blank for now unless you
# know what you are doing.

# API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Model id, e.g. claude-haiku-4-5-20251001, claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ==================== BUDGETS (tune to taste) ====================
SESSION_TOKEN_BUDGET=200000
SESSION_USD_BUDGET=2.00

# Optional: override the default price table. Prices are per 1M
# tokens. Nested by provider: {"openai":{"gpt-4o-mini":{"input":0.15,"output":0.60}}}.
# Defaults in code cover gpt-4o-mini / gpt-4o / claude-haiku-4-5 /
# claude-sonnet-4-6 / claude-opus-4-7. Leave blank to use those.
PRICE_TABLE_JSON=


# ==================== OPTIONAL: Azure AI Search ====================
# If all three are set, the Research Assistant agent uses Azure
# AI Search. Otherwise it falls back to a local SQLite FTS5 index
# seeded from api/sample_docs/*.md — you still get a working demo.

AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_KEY=
AZURE_AI_SEARCH_INDEX=quickstart-docs


# ==================== OPTIONAL: Application Insights ====================
# If set, traces are also sent to Application Insights via the
# azure-monitor-opentelemetry distro. The UI still reads from the
# in-memory ring buffer either way.

APPLICATIONINSIGHTS_CONNECTION_STRING=
